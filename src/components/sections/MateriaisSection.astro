---
import Section from '@/components/layout/Section.astro'
import MaterialCard from '@/components/cards/MaterialCard.astro'
import PdfViewerModal from '@/components/react/PdfViewerModal'
import { materiais } from '@/data/materiais'

const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const { variant } = Astro.props
const materiaisNaoVideo = materiais.filter(item => item.tipo !== 'video')
---

<Section id="materiais" title="Materiais" variant={variant}>
  <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-3xl">
    Produções da equipe da COOVIG: cadernos técnicos, orientações, seminários e materiais de apoio para as equipes municipais de Vigilância Socioassistencial.
  </p>
  <div class="space-y-3">
    {materiaisNaoVideo.map((item) => (
      <details class="group border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer bg-slate-50 dark:bg-slate-800/50 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors list-none select-none">
          <div class="flex items-center gap-3">
            <span class="font-bold text-slate-800 dark:text-white">{item.titulo}</span>
            <span class="text-xs font-semibold uppercase tracking-wider text-institucional-blue dark:text-blue-300">{item.tipo}</span>
            {item.data && <span class="text-xs text-slate-400 dark:text-slate-500">{item.data}</span>}
          </div>
          <svg class="w-5 h-5 text-slate-400 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-5 pt-1">
          <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">{item.descricao}</p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {item.tags.map(tag => (
              <span class="inline-block px-2 py-0.5 text-[11px] font-medium rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">{tag}</span>
            ))}
          </div>
          {item.tipo === 'pdf' ? (
            <PdfViewerModal
              client:visible
              titulo={item.titulo}
              descricao={item.descricao}
              pdfUrl={`${base}/${item.url.replace(/^\/+/, '')}`}
              thumbnail={item.thumbnail ? `${base}/${item.thumbnail.replace(/^\/+/, '')}` : undefined}
              tipo={item.tipo}
              data={item.data}
              tags={item.tags}
            />
          ) : (
            <MaterialCard item={item} />
          )}
        </div>
      </details>
    ))}
  </div>
  {materiaisNaoVideo.length === 0 && (
    <div class="text-center py-12 text-slate-400 dark:text-slate-500">
      <p class="text-lg">Materiais em breve.</p>
      <p class="text-sm mt-2">A equipe está preparando os conteúdos.</p>
    </div>
  )}

</Section>
