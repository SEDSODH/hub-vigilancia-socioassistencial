---
import Section from '@/components/layout/Section.astro'
import { ExternalLink } from 'lucide-react'
import { referencias } from '@/data/referencias'

const { variant } = Astro.props
const portais = referencias.filter(item => item.tipo === 'portal')
---

<Section id="portais" title="Sistemas e Portais" variant={variant}>
  <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-3xl">
    Sistemas e portais oficiais do SUAS utilizados no dia a dia da Vigilância Socioassistencial. Links externos — abrem em nova aba. Manuais e formulários destes sistemas estão disponíveis na seção Sistemas SUAS.
  </p>
  <div class="space-y-3">
    {portais.map((item) => (
      <details class="group border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer bg-slate-50 dark:bg-slate-800/50 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors list-none select-none">
          <div class="flex items-center gap-3">
            <span class="font-bold text-slate-800 dark:text-white">{item.titulo}</span>
          </div>
          <svg
            class="w-5 h-5 text-slate-400 transition-transform duration-200 group-open:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-5 pt-1">
          <p class="text-slate-500 dark:text-slate-400 mb-3">{item.descricao}</p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {item.tags.map((tag) => (
              <span class="inline-flex px-2 py-0.5 text-[11px] rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
                {tag}
              </span>
            ))}
          </div>
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 rounded-lg transition-colors"
          >
            <ExternalLink client:load className="w-4 h-4" />
            Acessar
          </a>
        </div>
      </details>
    ))}
  </div>
</Section>
