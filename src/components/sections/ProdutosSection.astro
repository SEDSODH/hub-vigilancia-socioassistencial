---
import Section from '@/components/layout/Section.astro'
import SitePreviewModal from '@/components/react/SitePreviewModal'
import { ExternalLink } from 'lucide-react'

const { variant } = Astro.props

const produtos = [
  {
    id: 'suas-em-dados',
    titulo: 'SUAS em Dados',
    descricao: 'Plataforma interativa de visualização e consulta de dados do Sistema Único de Assistência Social. Desenvolvida pela equipe da COOVIG para apoiar a tomada de decisão baseada em evidências nos municípios do Estado do Rio de Janeiro.',
    url: 'https://suas-em-dados.cloud/',
    destaque: true,
  },
  {
    id: 'guia-implantacao',
    titulo: 'Guia de Implantação',
    descricao: 'Roteiro completo em 4 blocos para apoiar os municípios na estruturação da Vigilância Socioassistencial.',
    url: 'https://hub-vigilancia.sedsodh.org/',
    destaque: false,
  },
  {
    id: 'gofsuas',
    titulo: 'Sistema de Gestão Orçamentária e Financeira do SUAS',
    descricao: 'Plataforma GOFSUAS para acompanhamento e gestão dos recursos orçamentários e financeiros da assistência social.',
    url: 'https://gofsuasrj.org/',
    destaque: false,
  },
  {
    id: 'caderno-gofsuas',
    titulo: 'Caderno de Orientações — Gestão Orçamentária e Financeira',
    descricao: 'Material de referência com orientações detalhadas para a gestão orçamentária e financeira do SUAS nos municípios.',
    url: 'https://caderno.gofsuasrj.org/',
    destaque: false,
  },
  {
    id: 'boletim-supgs',
    titulo: 'Boletim da SUPGS',
    descricao: 'Publicação periódica da Superintendência de Planejamento e Gestão do SUAS com análises, dados e orientações.',
    url: 'https://sites.google.com/view/boletimsupgsrj/',
    destaque: false,
    semPreview: true,
  },
  {
    id: 'faq-peti',
    titulo: 'FAQ do PETI Estadual RJ',
    descricao: 'Perguntas frequentes sobre o Programa de Erradicação do Trabalho Infantil (PETI) no Estado do Rio de Janeiro.',
    url: 'https://sites.google.com/view/faqpeti-rj/in%C3%ADcio',
    destaque: false,
    semPreview: true,
  },
]

const destaques = produtos.filter(p => p.destaque)
const outros = produtos.filter(p => !p.destaque)
---

<Section id="produtos" title="Produtos da Vigilância Socioassistencial (COOVIG)" variant={variant}>
  <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-3xl">
    Conheça as plataformas, publicações e sistemas desenvolvidos pela Coordenação Estadual
    de Vigilância Socioassistencial para apoiar os municípios fluminenses.
  </p>

  <!-- Featured products (full-width cards) -->
  <div class="space-y-6 mb-10">
    {destaques.map(produto => (
      <div class="relative bg-gradient-to-br from-institucional-blue via-blue-700 to-indigo-800 dark:from-blue-950 dark:via-slate-900 dark:to-indigo-950 rounded-2xl p-6 md:p-8 text-white shadow-xl ring-1 ring-white/10 overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl pointer-events-none" />
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-blue-400/10 rounded-full translate-y-1/3 -translate-x-1/4 blur-2xl pointer-events-none" />
        <div class="relative flex flex-col lg:flex-row lg:items-center gap-6">
          <div class="flex-1">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-400/20 text-emerald-200 text-xs font-bold uppercase tracking-wider mb-4 ring-1 ring-emerald-400/30">
              <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
              Sistema desenvolvido pela COOVIG
            </div>
            <h3 class="text-2xl md:text-3xl font-extrabold mb-3">{produto.titulo}</h3>
            <p class="text-blue-100/90 leading-relaxed max-w-2xl text-sm md:text-base">{produto.descricao}</p>
            <div class="flex flex-wrap gap-3 mt-6">
              <a
                href={produto.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white text-institucional-blue font-bold text-sm hover:bg-blue-50 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 shadow-md no-underline"
              >
                Acessar
                <ExternalLink className="w-4 h-4" />
              </a>
            </div>
          </div>
          <div class="shrink-0 w-full sm:w-56 lg:w-64">
            <SitePreviewModal
              client:visible
              url={produto.url}
              titulo={produto.titulo}
            />
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Other products grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 animate-on-scroll stagger">
    {outros.map(produto => (
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="flex items-start gap-4">
          <div class="shrink-0 w-44">
            {produto.semPreview ? (
              <a
                href={produto.url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:shadow-lg hover:-translate-y-0.5 hover:border-institucional-blue/40 dark:hover:border-blue-500/40 transition-all duration-300 no-underline block relative"
              >
                <div class="flex items-center gap-1.5 px-2.5 py-1.5 bg-slate-50 dark:bg-slate-800/80 border-b border-slate-200 dark:border-slate-700">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-400/70" />
                  <span class="w-1.5 h-1.5 rounded-full bg-yellow-400/70" />
                  <span class="w-1.5 h-1.5 rounded-full bg-green-400/70" />
                  <span class="ml-1 text-[9px] text-slate-400 dark:text-slate-500 truncate">sites.google.com</span>
                </div>
                <div class="aspect-[4/3] bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-700 dark:to-slate-800 flex items-center justify-center">
                  <div class="text-center px-2">
                    <ExternalLink className="w-7 h-7 text-slate-300 dark:text-slate-600 mx-auto mb-1.5" />
                    <span class="text-[10px] text-slate-400 dark:text-slate-500 font-medium line-clamp-2">{produto.titulo}</span>
                  </div>
                  <div class="absolute top-2 right-2 flex items-center gap-1 px-1.5 py-0.5 rounded bg-slate-900/40 dark:bg-slate-900/60 text-[10px] text-white/70 font-medium">
                    <ExternalLink className="w-3 h-3" />
                    Acessar
                  </div>
                </div>
              </a>
            ) : (
              <SitePreviewModal
                client:visible
                url={produto.url}
                titulo={produto.titulo}
              />
            )}
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-bold text-slate-800 dark:text-white mb-1">{produto.titulo}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-3 mb-3">{produto.descricao}</p>
            <a
              href={produto.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-institucional-blue dark:text-blue-400 hover:underline"
            >
              Acessar
              <ExternalLink className="w-3.5 h-3.5" />
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</Section>
